{
  "basic_config": {
    "description": "基础功能",
    "hint": "控制插件总开关及模型发送工具引导。",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用提示词编排",
        "type": "bool",
        "default": true
      },
      "tool_delivery_enabled": {
        "description": "启用发送工具引导",
        "hint": "仅适用于需要模型主动调用 send_message_to_user 的 Agent 场景。开启后会临时引导模型把正文放入工具调用，可能造成普通回复为空或重复发送；普通聊天建议关闭。",
        "type": "bool",
        "default": false
      }
    }
  },
  "context_config": {
    "description": "上下文与裁剪",
    "hint": "控制 token 预算、输出预留和发送给模型的聊天历史范围。",
    "type": "object",
    "items": {
      "context_budget": {
        "description": "默认上下文预算（token）",
        "hint": "无法从模型元数据取得上限时使用。",
        "type": "int",
        "default": 32768
      },
      "output_reserve": {
        "description": "输出预留（token）",
        "type": "int",
        "default": 2048
      },
      "history_max_messages": {
        "description": "最多发送聊天历史消息数",
        "hint": "只发送最近 N 条聊天记录；不计算本次用户消息和插件注入消息。0 表示不限制，12 通常约为 6 轮。",
        "type": "int",
        "default": 12
      },
      "history_first_trimming": {
        "description": "优先裁剪旧聊天历史",
        "hint": "超出 token 预算时先裁剪旧历史，再裁剪可选提示块。",
        "type": "bool",
        "default": true
      },
      "history_keep_recent_messages": {
        "description": "预算裁剪时优先保留的最近消息数",
        "hint": "第一阶段不会删除这些最近消息；若仍超出硬上限则继续裁剪。建议 4-10。",
        "type": "int",
        "default": 6
      }
    }
  },
  "summary_config": {
    "description": "自动摘要与历史压缩",
    "hint": "用独立小模型把较旧聊天合并进会话摘要，并注入 Prompt Manager 的 Summary 块。默认关闭。",
    "type": "object",
    "items": {
      "summary_enabled": {
        "description": "启用自动摘要",
        "hint": "开启后会产生额外模型调用。建议先选择成本较低、上下文足够的小模型。",
        "type": "bool",
        "default": false
      },
      "summary_provider_id": {
        "description": "摘要 Provider ID",
        "hint": "留空使用当前会话 Provider；填写后若该 Provider 不可用会直接降级，不会静默切换模型。",
        "type": "string",
        "_special": "select_provider",
        "default": ""
      },
      "summary_trigger_messages": {
        "description": "触发摘要的未压缩消息数",
        "hint": "必须大于“最多发送聊天历史消息数”。默认 18，配合保留 12 条时每次压缩最旧 6 条。",
        "type": "int",
        "default": 18
      },
      "summary_max_tokens": {
        "description": "摘要最大输出 token",
        "type": "int",
        "default": 1024
      },
      "summary_timeout_seconds": {
        "description": "摘要调用超时（秒）",
        "type": "int",
        "default": 60
      },
      "summary_prompt": {
        "description": "摘要提示词",
        "hint": "支持 {previous_summary} 和 {history} 占位符。",
        "type": "text",
        "default": "请把以下旧聊天记录压缩成可供后续角色扮演继续使用的会话摘要。\n保留人物关系、重要事实、事件顺序、承诺、状态变化、未解决事项和持续有效的偏好。\n不要续写剧情，不要添加原文没有的信息，不要输出标题之外的解释。\n\n已有摘要：\n{previous_summary}\n\n新增旧聊天记录：\n{history}\n"
      }
    }
  },
  "lifecycle_config": {
    "description": "会话数据生命周期",
    "hint": "自动清理不活跃的插件状态和调试预览，不会删除 AstrBot 聊天、角色资料或绑定。",
    "type": "object",
    "items": {
      "cleanup_enabled": {
        "description": "启用自动过期清理",
        "type": "bool",
        "default": true
      },
      "session_retention_days": {
        "description": "会话状态保留天数",
        "hint": "过期后会重置世界书生命周期、状态变量和滚动摘要。",
        "type": "int",
        "default": 30
      },
      "preview_retention_days": {
        "description": "真实请求预览保留天数",
        "type": "int",
        "default": 7
      },
      "cleanup_interval_hours": {
        "description": "清理检查间隔（小时）",
        "type": "int",
        "default": 24
      }
    }
  },
  "worldbook_config": {
    "description": "世界书与向量",
    "hint": "控制世界书扫描、递归激活及可选向量匹配。",
    "type": "object",
    "items": {
      "scan_depth": {
        "description": "默认世界书扫描深度",
        "type": "int",
        "default": 4
      },
      "max_recursion_steps": {
        "description": "最大递归扫描次数",
        "type": "int",
        "default": 3
      },
      "vector_enabled": {
        "description": "启用向量条目",
        "type": "bool",
        "default": false
      },
      "embedding_provider_id": {
        "description": "Embedding Provider ID",
        "type": "string",
        "default": ""
      }
    }
  },
  "qq_direct_config": {
    "description": "QQ 普通消息分片",
    "hint": "长回复直接拆成多条普通 QQ 消息发送；开启后优先于合并转发。",
    "type": "object",
    "items": {
      "qq_direct_split_enabled": {
        "description": "启用逐条直接发送",
        "type": "bool",
        "default": false
      },
      "qq_direct_message_chars": {
        "description": "每条最大字符数",
        "hint": "按 Unicode 字符计数，推荐 1000-2000。",
        "type": "int",
        "default": 1000
      },
      "qq_direct_send_interval_ms": {
        "description": "发送间隔（毫秒）",
        "hint": "避免连续发送过快触发限流，推荐 500-1500。",
        "type": "int",
        "default": 2000
      },
      "qq_direct_retry_count": {
        "description": "失败重试次数",
        "type": "int",
        "default": 2
      },
      "qq_direct_retry_delay_ms": {
        "description": "重试等待（毫秒）",
        "type": "int",
        "default": 3000
      }
    }
  },
  "qq_forward_config": {
    "description": "QQ 合并转发",
    "hint": "将长回复拆成多个 Node 和多个小型合并转发包，仅作用于 aiocqhttp。",
    "type": "object",
    "items": {
      "qq_forward_split_enabled": {
        "description": "启用合并转发",
        "type": "bool",
        "default": true
      },
      "qq_forward_trigger_chars": {
        "description": "触发字符数",
        "hint": "中文、英文、标点和换行均按 Unicode 字符计数。",
        "type": "int",
        "default": 1500
      },
      "qq_forward_node_chars": {
        "description": "每个 Node 最大字符数",
        "hint": "推荐 800-1200，优先按段落和句末拆分。",
        "type": "int",
        "default": 1000
      },
      "qq_forward_nodes_per_batch": {
        "description": "每个转发包最大节点数",
        "hint": "推荐 6-8，超出后拆成多个转发包。",
        "type": "int",
        "default": 6
      },
      "qq_forward_batch_interval_ms": {
        "description": "转发包发送间隔（毫秒）",
        "type": "int",
        "default": 1500
      },
      "qq_forward_fallback_enabled": {
        "description": "失败时自动降级",
        "hint": "将尚未成功发送的内容改为普通消息分片。",
        "type": "bool",
        "default": true
      }
    }
  },
  "status_config": {
    "description": "状态栏",
    "hint": "解析模型回复中的状态数据并按模板附加显示。",
    "type": "object",
    "items": {
      "status_bar_enabled": {
        "description": "启用状态栏解析",
        "type": "bool",
        "default": false
      },
      "status_bar_template": {
        "description": "状态栏格式",
        "hint": "使用 {content} 放置解析后的状态。",
        "type": "text",
        "default": "**Status**\n```\n{content}\n```"
      }
    }
  },
  "illustration_config": {
    "description": "自动配图",
    "hint": "每次 LLM 回复后可异步调用生图插件补发一张图片。",
    "type": "object",
    "items": {
      "illustration_enabled": {
        "description": "启用自动配图",
        "type": "bool",
        "default": false
      },
      "illustration_plugin_id": {
        "description": "生图插件 ID",
        "type": "string",
        "default": "astrbot_plugin_omnidraw"
      },
      "illustration_mode": {
        "description": "配图模式",
        "type": "string",
        "options": ["text2img", "selfie"],
        "default": "text2img"
      },
      "illustration_max_text_chars": {
        "description": "传入生图的回复最大字符数",
        "hint": "建议 200-800，过长可能导致副脑超时。",
        "type": "int",
        "default": 600
      },
      "illustration_size": {
        "description": "配图默认尺寸",
        "hint": "留空使用生图插件默认尺寸，例如 1024x1024。",
        "type": "string",
        "default": ""
      },
      "illustration_consume_quota": {
        "description": "是否消耗用户额度",
        "type": "bool",
        "default": false
      },
      "illustration_prompt_prefix": {
        "description": "配图提示词前缀",
        "type": "text",
        "default": ""
      },
      "illustration_max_concurrency": {
        "description": "配图最大并发数",
        "hint": "推荐 1-3。",
        "type": "int",
        "default": 2
      }
    }
  }
}
